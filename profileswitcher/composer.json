{
    "name": "ecyaz/profileSwitcher",
    "type": "phpbb-extension",
    "description": "An extension for phpBB 3.3 boards that allows to change the location of profiles in posts (to choose the left or the right side).",
    "homepage": "http://phpbbguru.net",
    "version": "1.0.1",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Татьяна5",
            "homepage": "http://phpbbguru.net",
            "role": "Developer"
        },
        {
            "name": "LavIgor",
            "homepage": "https://github.com/lavigor",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.1.3"
    },
    "require-dev": {
        "phpbb/epv": "dev-master"
    },
    "extra": {
        "display-name": "Profile side switcher",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        }
    }
}
